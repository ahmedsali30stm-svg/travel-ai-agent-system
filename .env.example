# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_ai

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI (for agent reasoning)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview

# Travel Providers
HOTELBEDS_API_KEY=your-hotelbeds-api-key
HOTELBEDS_SECRET=your-hotelbeds-secret
BOOKING_API_KEY=your-booking-api-key
VIATOR_API_KEY=your-viator-api-key
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_SECRET=your-amadeus-secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Monitoring
PROMETHEUS_PORT=9090
LOG_LEVEL=info

# Browser Pool
BROWSER_POOL_MIN=3
BROWSER_POOL_MAX=20
BROWSER_HEADLESS=true

# Search
SEARCH_TIMEOUT=15000
SEARCH_MAX_RESULTS=50
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
